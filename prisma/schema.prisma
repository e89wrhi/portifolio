generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BlogPost {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  excerpt      String
  content      String
  coverImage String?
  authorId     String
  tags         String[]
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
